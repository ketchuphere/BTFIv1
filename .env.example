# ============================================================
# BTFI — Bengaluru Traffic Flow Intelligence
# Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ============================================================

# --- Database (required for DB package; not used by default API) ---
DATABASE_URL=postgresql://user:password@localhost:5432/btfi

# --- Session Security (required by Express session middleware) ---
SESSION_SECRET=replace-with-a-long-random-string

# --- Mappls (MapmyIndia) — Map SDK / Traffic Layer ---
#
# Option A: Static REST Map SDK key (tile URLs only)
#   Obtain from https://apis.mappls.com/ → Map SDK key
#   This key goes directly into tile URLs and is safe to expose in frontend.
VITE_MAPPLS_REST_KEY=

# Option B: OAuth Client credentials (recommended — enables full traffic API)
#   The API server exchanges these for an access token at /api/mappls/token.
#   These are NEVER sent to the browser — server-side only.
MAPPLS_CLIENT_ID=
MAPPLS_CLIENT_SECRET=

# Legacy alias — kept for backward compatibility (same as VITE_MAPPLS_REST_KEY)
VITE_MAPPLS_STATIC_KEY=

# --- Runtime (auto-set by Replit workflows; only needed for local dev) ---
# PORT and BASE_PATH are injected automatically by the Replit artifact system.
# Set them manually only when running outside Replit.
PORT=8080
BASE_PATH=/

# --- API Server only ---
NODE_ENV=development
LOG_LEVEL=info
